# Optional SMTP settings for access attempt notifications. If omitted, kiosk operation continues and email API returns skipped=true.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=qr-kiosk@example.com
SMTP_PASS=replace-with-smtp-password
EMAIL_FROM=qr-kiosk@example.com
EMAIL_TO=admin@example.com
